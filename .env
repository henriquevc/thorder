# CONFIGURAÇÃO DE BANCO DE DADOS - TURSO DB
#
# Para que todos os dispositivos (incluindo seu celular) tenham acesso ao mesmo banco de dados 
# de forma automática e integrada, preencha as variáveis abaixo com as credenciais do seu Turso DB.
#
# DICA: Ao rodar 'npm run dev' na mesma rede Wi-Fi, ou ao publicar no Vercel/Netlify, 
# a aplicação lerá essas variáveis e se conectará automaticamente!

# Cole a URL completa fornecida pelo painel do Turso (exemplo: libsql://seu-banco-usuario.turso.io)
VITE_TURSO_DB_URL=

# Cole o token de autenticação gerado pelo Turso
VITE_TURSO_DB_TOKEN=
